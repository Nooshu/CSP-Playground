{
  "name": "csp-builder",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "pages:dev": "yarn build && wrangler pages dev dist",
    "pages:deploy": "yarn build && wrangler pages deploy dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify:deps": "node scripts/verify-deps-integrity.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260617.1",
    "@types/node": "25.9.3",
    "@vitest/coverage-v8": "3.2.4",
    "jsdom": "29.1.1",
    "typescript": "5.9.3",
    "vite": "6.4.3",
    "vitest": "3.2.4",
    "wrangler": "4.101.0"
  }
}
