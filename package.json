{
  "name": "csp-playground",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nooshu/CSP-Playground.git"
  },
  "bugs": {
    "url": "https://github.com/Nooshu/CSP-Playground/issues"
  },
  "homepage": "https://csp-playground.dev",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build": "yarn typecheck && vite build && node scripts/generate-dist-headers.mjs && node scripts/compress-dist-brotli.mjs",
    "preview": "vite preview",
    "preview:dist": "node scripts/preview-dist.mjs",
    "preview:brotli": "yarn build && node scripts/preview-dist.mjs",
    "pages:dev": "yarn build && wrangler pages dev dist",
    "pages:deploy": "yarn build && wrangler pages deploy dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "verify:deps": "node scripts/verify-deps-integrity.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@cloudflare/workers-types": "4.20260620.1",
    "@playwright/test": "1.61.0",
    "@types/node": "25.9.4",
    "@vitest/coverage-istanbul": "4.1.9",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "wrangler": "4.103.0"
  }
}
