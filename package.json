{
  "name": "csp-playground",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nooshu/CSP-Playground.git"
  },
  "bugs": {
    "url": "https://github.com/Nooshu/CSP-Playground/issues"
  },
  "homepage": "https://csp-playground.dev",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/generate-dist-headers.mjs && node scripts/compress-dist-brotli.mjs",
    "preview": "vite preview",
    "preview:dist": "node scripts/preview-dist.mjs",
    "preview:brotli": "yarn build && node scripts/preview-dist.mjs",
    "pages:dev": "yarn build && wrangler pages dev dist",
    "pages:deploy": "yarn build && wrangler pages deploy dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify:deps": "node scripts/verify-deps-integrity.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260617.1",
    "@types/node": "25.9.3",
    "@vitest/coverage-istanbul": "4.1.9",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "wrangler": "4.101.0"
  }
}
