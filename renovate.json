{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":pinAllExceptPeerDependencies"
  ],
  "timezone": "Europe/London",
  "schedule": ["* 6 * * *"],
  "labels": ["dependencies"],
  "assignees": ["Nooshu"],
  "reviewers": ["Nooshu"],
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "description": "GitHub Actions are updated by Dependabot (see .github/dependabot.yml)",
      "matchManagers": ["github-actions"],
      "enabled": false
    },
    {
      "description": "Pin exact versions in package.json (Yarn v1 policy)",
      "matchManagers": ["npm"],
      "rangeStrategy": "pin"
    },
    {
      "description": "Cloudflare Pages v3 pins Node; ignore Node version updates",
      "matchManagers": ["npm", "nvm"],
      "matchPackageNames": ["node"],
      "enabled": false
    },
    {
      "description": "Group patch/minor devDependency updates into one daily PR",
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "dev dependencies (non-major)"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  }
}
