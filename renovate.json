{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":pinAllExceptPeerDependencies"
  ],
  "timezone": "Europe/London",
  "schedule": ["at 6:00am"],
  "labels": ["dependencies"],
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "description": "Pin exact versions in package.json (Yarn v1 policy)",
      "matchManagers": ["npm"],
      "rangeStrategy": "pin"
    },
    {
      "description": "Group patch/minor devDependency updates into one daily PR",
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "dev dependencies (non-major)"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  }
}
